{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dbaops/agent/schemas/analysis_report.json",
  "title": "AnalysisReport",
  "type": "object",
  "required": ["request", "findings"],
  "properties": {
    "request": {"$ref": "analysis_request.json"},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "domain", "title"],
        "properties": {
          "id":        {"type": "string"},
          "domain":    {"type": "string", "enum": ["os", "db", "log"]},
          "title":     {"type": "string"},
          "severity":  {"type": "string", "enum": ["info", "warn", "error"]},
          "evidence":  {"type": "array"},
          "timestamp": {"type": "string", "format": "date-time"}
        }
      }
    },
    "hypotheses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "statement"],
        "properties": {
          "id":                     {"type": "string"},
          "statement":              {"type": "string"},
          "supporting_finding_ids": {"type": "array", "items": {"type": "string"}},
          "confidence":             {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    },
    "next_actions": {"type": "array", "items": {"type": "string"}},
    "markdown":     {"type": "string"}
  }
}
